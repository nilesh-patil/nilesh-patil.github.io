source "https://rubygems.org"

group :jekyll_plugins do
  gem "jekyll", "~> 4.3"
  gem "jekyll-feed"
  gem "jekyll-sitemap"
  gem "jekyll-redirect-from"
  gem "jekyll-include-cache"
  gem "jekyll-paginate"
  gem "jekyll-gist"
  gem "jemoji"
  gem "webrick", "~> 1.8"
end

# Ruby 4.0+ removed these from the default standard library.
# Jekyll and its transitive dependencies still require them.
gem "logger"
gem "csv"
gem "base64"
gem "bigdecimal"
gem "ostruct"
